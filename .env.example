# =============================================================================
# AgentCard v2.0 — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# [REQUIRED] fields must be set. Others have working defaults.
# =============================================================================


PORT=3010


# -----------------------------------------------------------------------------
# DATABASE  [REQUIRED]
# -----------------------------------------------------------------------------
# MySQL / TiDB connection string
# Local Docker:  mysql://agentcard:agentcard@db:3306/agentcard
# TiDB Cloud:    mysql://root:PASSWORD@HOST:4000/agentcard?ssl=true
DATABASE_URL=mysql://agentcard:agentcard_pass@db:3306/agentcard


# -----------------------------------------------------------------------------
# AUTHENTICATION  [REQUIRED]
# -----------------------------------------------------------------------------
# Secret for JWT session cookies — generate with: openssl rand -hex 32
#JWT_SECRET=change_me_to_a_random_32_char_secret
JWT_SECRET=b32d93abfdcc065fe2c3723493ef17b75cffff5de18367ab02db8586c53c1479

# Manus OAuth (auto-injected on Manus platform; fill manually for self-hosted)
#VITE_APP_ID=your_manus_app_id
#OAUTH_SERVER_URL=https://api.manus.im
#VITE_OAUTH_PORTAL_URL=https://manus.im


# -----------------------------------------------------------------------------
# MULTI-LLM ROUTER
# -----------------------------------------------------------------------------
# Route calls by complexity: COMPLEX (deep analysis) vs SIMPLE (fast/cheap).
# Leave as "built-in" to use Manus built-in LLM (no key needed).

# Complex task provider: anthropic | openai | groq | mistral | built-in
LLM_COMPLEX_PROVIDER=anthropic
# Model override (blank = provider default)
# Examples: claude-3-5-sonnet-20241022 | gpt-4o | llama-3.3-70b-versatile
LLM_COMPLEX_MODEL=claude-3-5-sonnet-20241022

# Simple task provider: groq | mistral | openai | built-in
LLM_SIMPLE_PROVIDER=openai
# Model override (blank = provider default)
# Examples: llama-3.1-8b-instant | mistral-small-latest | gpt-4o-mini
LLM_SIMPLE_MODEL=gpt-4o-mini

# --- Provider API Keys (only needed for the providers you enable above) ---

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (fast Llama 3, great for simple tasks) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=


# -----------------------------------------------------------------------------
# NEVERMINED — x402 Agent Payment Protocol
# -----------------------------------------------------------------------------
# Enables agent-to-agent payments. Get started: https://nevermined.app
# SDK docs: https://docs.nevermined.app

# API Key for the platform wallet (seller side)
# Get from: https://nevermined.app/en/profile/api-keys
#NVM_API_KEY=

# Environment: testing | production
#NVM_ENVIRONMENT=testing

# Platform wallet address (your Nevermined account address)
NVM_PLATFORM_ADDRESS=


# ── Nevermined (x402 cross-team agent-to-agent payments) ─────────────────────
# Get your API key: https://nevermined.app
# Run python -m backend.economy.register_agent to populate PLAN_ID + AGENT_ID
NVM_API_KEY=sandbox:eyJhbGciOiJFUzI1NksifQ..J3m_cUiSG7r3kZhUhgKSj3NX8v9ljnnksculzJhSgeRsTRxOoGMeVtHGKfPlCMz8GhOW_YA5HNnmfYFC3U2x5Bs

NVM_ENVIRONMENT=sandbox
