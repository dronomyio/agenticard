# -----------------------------------------------------------------------------
# ZEROCLICK — Contextual Ad Network
# -----------------------------------------------------------------------------
# Provides AI-native contextual offers shown after enhancements.
# Get your key: https://developer.zeroclick.ai

# API Key (use SERVER key for higher CPM; PUBLIC key as fallback)
ZEROCLICK_API_KEY=kMdGTuJ80UYdBqZ8uS5f2n5cSRYjq4_4BDHfOfpdlAM

# Method: server | client
# Use "server" once you have a server-side key from the ZeroClick dashboard
ZEROCLICK_METHOD=client


# -----------------------------------------------------------------------------
# MANUS BUILT-IN APIS (auto-injected on Manus platform)
# -----------------------------------------------------------------------------
# Leave blank for self-hosted deployments unless you have Manus Forge access.
BUILT_IN_FORGE_API_URL=https://api.manus.im/forge
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im/forge


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=production
VITE_APP_TITLE=AgentCard
OWNER_OPEN_ID=
OWNER_NAME=
